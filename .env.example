# URL base del backend (sin barra final)
# Ejemplo: https://localhost:7099 o https://api.midominio.com
NEXT_PUBLIC_API_URL=https://localhost:7099

# Modo kiosco (tablet).
# El frontend genera un `X-Kiosk-Device-Id` y lo guarda en localStorage.
# El backend debe validar que el dispositivo está permitido (idealmente por IP/red + device-id),
# ya que este modo NO usa JWT.
#
# Para bloquearlo temporalmente (recomendado mientras no se use), deja este flag en `false`.
NEXT_PUBLIC_ENABLE_KIOSK=false
